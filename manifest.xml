<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
  <Id>d2508892-2337-4183-93d3-eb80355f3032</Id>
  <Version>1.5.2</Version>
  <ProviderName>DeskManager Automation</ProviderName>
  <DefaultLocale>pt-BR</DefaultLocale>
  <DisplayName DefaultValue="Abrir Chamado DeskManager"/>
  <Description DefaultValue="Acelere a abertura de chamados no DeskManager a partir do Outlook."/>
  
  <IconUrl DefaultValue="https://appsforoffice.microsoft.com/fabric/assets/brand-icons/product/outlook-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://appsforoffice.microsoft.com/fabric/assets/brand-icons/product/outlook-80.png"/>
  
  <SupportUrl DefaultValue="https://www.deskmanager.com.br"/>
  <AppDomains>
    <AppDomain>https://desk-manager-extension.vercel.app</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://desk-manager-extension.vercel.app/src/taskpane/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenTicket">
                  <Label resid="TicketButtonLabel"/>
                  <Supertip>
                    <Title resid="TicketButtonTitle"/>
                    <Description resid="TicketButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://appsforoffice.microsoft.com/fabric/assets/brand-icons/product/outlook-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://appsforoffice.microsoft.com/fabric/assets/brand-icons/product/outlook-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://appsforoffice.microsoft.com/fabric/assets/brand-icons/product/outlook-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://desk-manager-extension.vercel.app/src/commands/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://desk-manager-extension.vercel.app/src/taskpane/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="DeskManager"/>
        <bt:String id="TicketButtonLabel" DefaultValue="Abrir Chamado"/>
        <bt:String id="TicketButtonTitle" DefaultValue="Abrir Chamado no DeskManager"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TicketButtonDesc" DefaultValue="Captura os dados do e-mail e inicia a abertura de um chamado no DeskManager."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
